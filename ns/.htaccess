Options +FollowSymLinks
RewriteEngine On

# Serve actual files directly (e.g. stones.ttl, stones.html)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Content negotiation for ontology namespace IRIs (e.g. /ns/stones or /ns/stones/)
# Uses absolute 303 redirects so trailing-slash variants work correctly.

# RDF/semantic web clients: redirect to Turtle
RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/x-turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml [OR]
RewriteCond %{HTTP_ACCEPT} application/owl\+xml
RewriteRule ^([^/.]+)/?$ /ns/$1.ttl [R=303,L]

# Browsers: redirect to HTML
RewriteRule ^([^/.]+)/?$ /ns/$1.html [R=303,L]
