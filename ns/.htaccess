Options +FollowSymLinks
RewriteEngine On

# Serve actual files directly (e.g. stones.ttl, stones.html)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Content negotiation for ontology IRIs (e.g. /ns/stones)
# Semantic web clients: serve Turtle
RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/x-turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml [OR]
RewriteCond %{HTTP_ACCEPT} application/owl\+xml
RewriteRule ^(.+)$ $1.ttl [L,T=text/turtle]

# Browser fallback: redirect to human-readable HTML page
RewriteRule ^(.+)$ $1.html [L]
