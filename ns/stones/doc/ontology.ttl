                                                                      <https://cyberterrain.org/ns/stonex#_REG_RESOURCE_LIST>
                                                                      <https://cyberterrain.org/ns/stonex#_REG_RESOURCE_REQUIREMENTS_LIST>
                                                                      <https://cyberterrain.org/ns/stonex#_REG_SZ>
                                                                    )
                                                        ] ;
                                    rdfs:subClassOf :Enumeration .


###  https://cyberterrain.org/ns/stones#WindowsRegistryKeyObject
:WindowsRegistryKeyObject rdf:type owl:Class ;
                          owl:equivalentClass [ owl:intersectionOf ( :StixObject
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty :stixType ;
                                                                       owl:hasValue "windows-registry-key"
                                                                     ]
                                                                   ) ;
                                                rdf:type owl:Class
                                              ] ;
                          rdfs:subClassOf :StixCyberobservableObject ;
                          rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
