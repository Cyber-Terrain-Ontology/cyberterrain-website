     <http://www.w3.org/2004/02/skos/core#definition> "TLP level for a TLP marking definition: 'white', 'green', 'amber', or 'red'." .


###  https://cyberterrain.org/ns/stones#toolVersion
:toolVersion rdf:type owl:DatatypeProperty ;
             rdfs:domain :Tool ;
             rdfs:range xsd:string ;
             rdfs:comment "(STIX: tool_version)" ;
             rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
             <http://www.w3.org/2004/02/skos/core#definition> "Version string of the tool." .


###  https://cyberterrain.org/ns/stones#uid
:uid rdf:type owl:DatatypeProperty ;
     rdfs:domain :UserAccountObject ;
     rdfs:range xsd:integer ;
     rdfs:comment "(STIX: unix-account-ext.uid)" ;
     rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
     <http://www.w3.org/2004/02/skos/core#definition> "Numeric UNIX user ID (UID)." .


###  https://cyberterrain.org/ns/stones#url
:url rdf:type owl:DatatypeProperty ;
     rdfs:range xsd:anyURI ;
     rdfs:comment "(STIX: url)" ;
     rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
     <http://www.w3.org/2004/02/skos/core#definition> "URL to a referenced resource (external-reference) or the location of artifact content." .


