:subjectDirectoryAttributes rdf:type owl:DatatypeProperty ;
                            rdfs:domain :X509V3Extensions ;
                            rdfs:range xsd:string ;
                            rdfs:comment "(STIX: x509-v3-extensions-type.subject_directory_attributes)" ;
                            rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
                            <http://www.w3.org/2004/02/skos/core#definition> "X.509 v3 subject directory attributes extension." .


