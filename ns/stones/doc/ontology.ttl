                          <http://www.w3.org/2004/02/skos/core#prefLabel> "Windows Registry Key Object"@en .


###  https://cyberterrain.org/ns/stones#WindowsRegistryValue
:WindowsRegistryValue rdf:type owl:Class ;
                      rdfs:subClassOf :StixSubType ;
                      rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
                      <http://www.w3.org/2004/02/skos/core#definition> "A single value entry within a Windows Registry key, comprising a name, a data string, and a registry data type." ;
                      <http://www.w3.org/2004/02/skos/core#prefLabel> "Windows Registry Value"@en .


###  https://cyberterrain.org/ns/stones#WindowsServiceStartTypeEnumeration
:WindowsServiceStartTypeEnumeration rdf:type owl:Class ;
                                    owl:equivalentClass [ rdf:type owl:Class ;
                                                          owl:oneOf ( <https://cyberterrain.org/ns/stonex#_SERVICE_AUTO_START>
                                                                      <https://cyberterrain.org/ns/stonex#_SERVICE_BOOT_START>
                                                                      <https://cyberterrain.org/ns/stonex#_SERVICE_DEMAND_START>
                                                                      <https://cyberterrain.org/ns/stonex#_SERVICE_DISABLED>
                                                                      <https://cyberterrain.org/ns/stonex#_SERVICE_SYSTEM_ALERT>
                                                                    )
                                                        ] ;
                                    rdfs:subClassOf :Enumeration .


###  https://cyberterrain.org/ns/stones#WindowsServiceStatusEnumeration
:WindowsServiceStatusEnumeration rdf:type owl:Class ;
                                 owl:equivalentClass [ rdf:type owl:Class ;
                                                       owl:oneOf ( <https://cyberterrain.org/ns/stonex#_SERVICE_CONTINUE_PENDING>
                                                                   <https://cyberterrain.org/ns/stonex#_SERVICE_PAUSED>
                                                                   <https://cyberterrain.org/ns/stonex#_SERVICE_PAUSE_PENDING>
                                                                   <https://cyberterrain.org/ns/stonex#_SERVICE_RUNNING>
                                                                   <https://cyberterrain.org/ns/stonex#_SERVICE_START_PENDING>
                                                                   <https://cyberterrain.org/ns/stonex#_SERVICE_STOPPED>
                                                                   <https://cyberterrain.org/ns/stonex#_SERVICE_STOP_PENDING>
                                                                 )
                                                     ] ;
                                 rdfs:subClassOf :Enumeration .


###  https://cyberterrain.org/ns/stones#WindowsServiceTypeEnumeration
:WindowsServiceTypeEnumeration rdf:type owl:Class ;
                               owl:equivalentClass [ rdf:type owl:Class ;
                                                     owl:oneOf ( <https://cyberterrain.org/ns/stonex#_SERVICE_FILE_SYSTEM_DRIVER>
                                                                 <https://cyberterrain.org/ns/stonex#_SERVICE_KERNEL_DRIVER>
                                                                 <https://cyberterrain.org/ns/stonex#_SERVICE_WIN32_OWN_PROCESS>
                                                                 <https://cyberterrain.org/ns/stonex#_SERVICE_WIN32_SHARE_PROCESS>
                                                               )
                                                   ] ;
                               rdfs:subClassOf :Enumeration .


###  https://cyberterrain.org/ns/stones#X509CertificateObject
:X509CertificateObject rdf:type owl:Class ;
                       owl:equivalentClass [ owl:intersectionOf ( :StixObject
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :stixType ;
                                                                    owl:hasValue "x509-certificate"
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ] ;
                       rdfs:subClassOf :StixCyberobservableObject ;
                       rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
                       <http://www.w3.org/2004/02/skos/core#definition> "Represents an X.509 digital certificate, capturing its subject, issuer, validity window, public key details, and optional v3 extensions." ;
                       <http://www.w3.org/2004/02/skos/core#prefLabel> "X.509 Certificate Object"@en .


###  https://cyberterrain.org/ns/stones#X509V3Extensions
:X509V3Extensions rdf:type owl:Class ;
                  rdfs:subClassOf :StixSubType ;
                  rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
                  <http://www.w3.org/2004/02/skos/core#definition> "The set of X.509 version 3 extension fields present in a digital certificate, such as key usage, subject alternative names, and CRL distribution points." ;
                  <http://www.w3.org/2004/02/skos/core#prefLabel> "X.509 v3 Extensions"@en .


