:sizeOfOptionalHeader rdf:type owl:DatatypeProperty ;
                      rdfs:range xsd:integer ;
                      rdfs:comment "(STIX: size_of_optional_header)" ;
                      rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
                      <http://www.w3.org/2004/02/skos/core#definition> "Size of the optional PE header in bytes." .


