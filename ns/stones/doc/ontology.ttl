             rdfs:range xsd:hexBinary ;
             rdfs:comment "(STIX: tcp-ext.src_flags_hex)" ;
             rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
             <http://www.w3.org/2004/02/skos/core#definition> "TCP flags set on packets from the source endpoint as hex, e.g. '0x02' for SYN." .


