       rdfs:domain :NetworkTrafficObject ;
       rdfs:range xsd:dateTime ;
       rdfs:comment "(STIX: start)" ;
       rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
       <http://www.w3.org/2004/02/skos/core#definition> "Timestamp when this network traffic flow started." .


###  https://cyberterrain.org/ns/stones#startTime
:startTime rdf:type owl:DatatypeProperty ;
           rdfs:domain :Relationship ;
           rdfs:range xsd:dateTime ;
           rdfs:comment "(STIX: start_time)" ;
           rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
           <http://www.w3.org/2004/02/skos/core#definition> "Timestamp when this relationship began." .


###  https://cyberterrain.org/ns/stones#statement
:statement rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:string ;
           rdfs:comment "(STIX: definition.statement)" ;
           rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
           <http://www.w3.org/2004/02/skos/core#definition> "Human-readable statement for a statement marking definition, e.g. a copyright notice." .


###  https://cyberterrain.org/ns/stones#stixId
:stixId rdf:type owl:DatatypeProperty ,
                 owl:FunctionalProperty ;
        rdfs:domain :StixObject ;
        rdfs:range xsd:string ;
        rdfs:comment "(STIX: id)" ;
        rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
        <http://www.w3.org/2004/02/skos/core#definition> "The STIX identifier string in the format <type>--<UUIDv4>. The IRI of the individual is the canonical identity; this property retains the string for JSON round-tripping and SPARQL querying." .


###  https://cyberterrain.org/ns/stones#stixType
:stixType rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :StixObject ;
          rdfs:range xsd:string ;
          rdfs:comment "(STIX: type)" ;
          rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
          <http://www.w3.org/2004/02/skos/core#definition> "The STIX object type string, e.g. 'attack-pattern'. Semantically redundant with rdf:type but preserved for JSON round-tripping." .


###  https://cyberterrain.org/ns/stones#stopTime
:stopTime rdf:type owl:DatatypeProperty ;
          rdfs:domain :Relationship ;
          rdfs:range xsd:dateTime ;
          rdfs:comment "(STIX: stop_time)" ;
          rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
          <http://www.w3.org/2004/02/skos/core#definition> "Timestamp when this relationship ended. MUST be >= startTime." .


