:srcPort rdf:type owl:DatatypeProperty ;
         rdfs:domain :NetworkTrafficObject ;
         rdfs:range xsd:integer ;
         rdfs:comment "(STIX: src_port)" ;
         rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
         <http://www.w3.org/2004/02/skos/core#definition> "Source port number (0–65535)." .


