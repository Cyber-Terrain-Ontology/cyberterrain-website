             rdfs:domain :StixObject ;
             rdfs:range xsd:string ;
             rdfs:comment "(STIX: spec_version)" ;
             rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
             <http://www.w3.org/2004/02/skos/core#definition> "STIX specification version. MUST be '2.1'." .


