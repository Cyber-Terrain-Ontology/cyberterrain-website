:socketDescriptor rdf:type owl:DatatypeProperty ;
                  rdfs:range xsd:integer ;
                  rdfs:comment "(STIX: socket-ext.socket_descriptor)" ;
                  rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
                  <http://www.w3.org/2004/02/skos/core#definition> "Platform-specific socket file descriptor number." .


