:userId rdf:type owl:DatatypeProperty ;
        rdfs:domain :UserAccountObject ;
        rdfs:range xsd:string ;
        rdfs:comment "(STIX: user_id)" ;
        rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
        <http://www.w3.org/2004/02/skos/core#definition> "Identifier of the user account, such as a login name or UID." .


###  https://cyberterrain.org/ns/stones#validFrom
:validFrom rdf:type owl:DatatypeProperty ;
           rdfs:domain :Indicator ;
           rdfs:range xsd:dateTime ;
           rdfs:comment "(STIX: valid_from)" ;
           rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
           <http://www.w3.org/2004/02/skos/core#definition> "Timestamp from which this indicator is considered valid." .


###  https://cyberterrain.org/ns/stones#validUntil
:validUntil rdf:type owl:DatatypeProperty ;
            rdfs:domain :Indicator ;
            rdfs:range xsd:dateTime ;
            rdfs:comment "(STIX: valid_until)" ;
            rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
            <http://www.w3.org/2004/02/skos/core#definition> "Timestamp after which this indicator is no longer valid." .


###  https://cyberterrain.org/ns/stones#validityNotAfter
:validityNotAfter rdf:type owl:DatatypeProperty ;
                  rdfs:domain :X509CertificateObject ;
                  rdfs:range xsd:dateTime ;
                  rdfs:comment "(STIX: validity_not_after)" ;
                  rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
                  <http://www.w3.org/2004/02/skos/core#definition> "End of the certificate validity period." .


###  https://cyberterrain.org/ns/stones#validityNotBefore
:validityNotBefore rdf:type owl:DatatypeProperty ;
                   rdfs:domain :X509CertificateObject ;
                   rdfs:range xsd:dateTime ;
                   rdfs:comment "(STIX: validity_not_before)" ;
                   rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
                   <http://www.w3.org/2004/02/skos/core#definition> "Start of the certificate validity period." .


###  https://cyberterrain.org/ns/stones#value
:value rdf:type owl:DatatypeProperty ;
       rdfs:range xsd:string ;
       rdfs:comment "(STIX: value)" ;
       rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
       <http://www.w3.org/2004/02/skos/core#definition> "Primary string value of an observable: the domain name, email address, IP address, MAC address, or URL." .


###  https://cyberterrain.org/ns/stones#vendor
:vendor rdf:type owl:DatatypeProperty ;
        rdfs:domain :SoftwareObject ;
        rdfs:range xsd:string ;
        rdfs:comment "(STIX: vendor)" ;
        rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
        <http://www.w3.org/2004/02/skos/core#definition> "Name of the software vendor." .


###  https://cyberterrain.org/ns/stones#version
:version rdf:type owl:DatatypeProperty ;
         rdfs:range xsd:string ;
         rdfs:comment "(STIX: version)" ;
         rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
         <http://www.w3.org/2004/02/skos/core#definition> "Version string. Used for analysis tool version (malware-analysis), schema version (extension-definition), software version, X.509 version, and PDF format version." .


