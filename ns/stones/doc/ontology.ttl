:WindowsRegistryDatatypeEnumeration rdf:type owl:Class ;
                                    owl:equivalentClass [ rdf:type owl:Class ;
                                                          owl:oneOf ( <https://cyberterrain.org/ns/stonex#_REG_BINARY>
                                                                      <https://cyberterrain.org/ns/stonex#_REG_DWORD>
                                                                      <https://cyberterrain.org/ns/stonex#_REG_DWORD_BIG_ENDIAN>
