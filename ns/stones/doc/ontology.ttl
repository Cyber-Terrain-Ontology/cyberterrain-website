     <http://www.w3.org/2004/02/skos/core#definition> "Regional Internet Registry that assigned this ASN, e.g. 'ARIN', 'RIPE'." .


###  https://cyberterrain.org/ns/stones#roles
:roles rdf:type owl:DatatypeProperty ;
       rdfs:domain :Identity ;
       rdfs:range xsd:string ;
       rdfs:comment "(STIX: roles)" ;
       rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
       <http://www.w3.org/2004/02/skos/core#definition> "Free-form roles this identity plays, e.g. 'analyst'. For threat-actor roles see the object property stones:threatActorRoles." .


###  https://cyberterrain.org/ns/stones#schema
:schema rdf:type owl:DatatypeProperty ;
        rdfs:domain :ExtensionDefinitionObject ;
        rdfs:range xsd:string ;
        rdfs:comment "(STIX: schema)" ;
        rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
        <http://www.w3.org/2004/02/skos/core#definition> "URL pointing to, or the raw content of, the JSON Schema defining this extension." .


###  https://cyberterrain.org/ns/stones#selectors
:selectors rdf:type owl:DatatypeProperty ;
           rdfs:domain :GranularMarking ;
           rdfs:range xsd:string ;
           rdfs:comment "(STIX: selectors)" ;
           rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
           <http://www.w3.org/2004/02/skos/core#definition> "JSON property path selectors identifying the properties this marking applies to, e.g. 'name', 'description'. Multiple values as multiple triples." .


###  https://cyberterrain.org/ns/stones#serialNumber
:serialNumber rdf:type owl:DatatypeProperty ;
              rdfs:domain :X509CertificateObject ;
              rdfs:range xsd:string ;
              rdfs:comment "(STIX: serial_number)" ;
              rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
              <http://www.w3.org/2004/02/skos/core#definition> "Serial number assigned to this certificate by the issuer." .


###  https://cyberterrain.org/ns/stones#serviceName
:serviceName rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:string ;
             rdfs:comment "(STIX: windows-service-ext.service_name)" ;
             rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
             <http://www.w3.org/2004/02/skos/core#definition> "Windows service name as used in the Service Control Manager." .


###  https://cyberterrain.org/ns/stones#shell
:shell rdf:type owl:DatatypeProperty ;
       rdfs:domain :UserAccountObject ;
       rdfs:range xsd:string ;
       rdfs:comment "(STIX: unix-account-ext.shell)" ;
       rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
       <http://www.w3.org/2004/02/skos/core#definition> "Login shell path for this UNIX account, e.g. '/bin/bash'." .


###  https://cyberterrain.org/ns/stones#sid
:sid rdf:type owl:DatatypeProperty ;
     rdfs:range xsd:string ;
     rdfs:comment "(STIX: sid / owner_sid)" ;
     rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
     <http://www.w3.org/2004/02/skos/core#definition> "Windows Security Identifier (SID) of the file owner (ntfs-ext) or process owner (windows-process-ext)." .


