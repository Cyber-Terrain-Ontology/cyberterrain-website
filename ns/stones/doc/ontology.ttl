:size rdf:type owl:DatatypeProperty ;
      rdfs:range xsd:integer ;
      rdfs:comment "(STIX: size)" ;
      rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
      <http://www.w3.org/2004/02/skos/core#definition> "Size in bytes (file, windows-pe-section, alternate-data-stream)." .


