:submitted rdf:type owl:DatatypeProperty ;
           rdfs:domain :MalwareAnalysis ;
           rdfs:range xsd:dateTime ;
           rdfs:comment "(STIX: submitted)" ;
           rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
