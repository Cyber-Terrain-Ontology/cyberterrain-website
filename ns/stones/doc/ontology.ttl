:sourceName rdf:type owl:DatatypeProperty ;
            rdfs:domain :ExternalReference ;
            rdfs:range xsd:string ;
            rdfs:comment "(STIX: source_name)" ;
            rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
            <http://www.w3.org/2004/02/skos/core#definition> "Name of the information source, e.g. 'mitre-attack', 'cve', 'capec'." .


###  https://cyberterrain.org/ns/stones#specVersion
