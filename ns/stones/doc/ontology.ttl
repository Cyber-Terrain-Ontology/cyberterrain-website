:srcPackets rdf:type owl:DatatypeProperty ;
            rdfs:domain :NetworkTrafficObject ;
            rdfs:range xsd:integer ;
            rdfs:comment "(STIX: src_packets)" ;
            rdfs:isDefinedBy <https://cyberterrain.org/ns/stones#> ;
            <http://www.w3.org/2004/02/skos/core#definition> "Number of packets sent from source to destination." .


