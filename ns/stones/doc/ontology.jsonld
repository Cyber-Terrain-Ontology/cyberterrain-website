    "@id" : "https://cyberterrain.org/ns/stones#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://cyberterrain.org/ns/stones#StixCoreObject"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Abstract class for STIX Cyber Observable Objects (SCOs), which represent technical observations such as IP addresses, files, network traffic, and processes."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "STIX Cyber Observable Object"
  } ]
}, {
  "@id" : "https://cyberterrain.org/ns/stones#StixDomainObject",
