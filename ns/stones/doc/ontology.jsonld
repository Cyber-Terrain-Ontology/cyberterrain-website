    "@id" : "_:genid176"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "Actual individuals, groups, or organisations believed to be operating with malicious intent. Unlike Identity, a ThreatActor carries adversarial connotations."
