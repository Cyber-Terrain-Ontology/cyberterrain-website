    "@id" : "_:genid171"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "A collection of arbitrary STIX objects used as a transport container. Bundles are not Core Objects, carry no modified timestamp, and cannot be referenced by identifier."
  } ],
