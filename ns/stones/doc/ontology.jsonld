    "@list" : [ {
      "@id" : "https://cyberterrain.org/ns/stones#stixId"
    } ]
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "The top-level abstract class for all STIX objects, encompassing STIX Core Objects (SDOs, SCOs, SROs), Meta Objects, and Bundles."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "STIX Object"
  } ]
}, {
  "@id" : "https://cyberterrain.org/ns/stones#StixRelationshipObject",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
