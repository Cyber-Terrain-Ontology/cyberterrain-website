        <skos:definition>Represents a file with its metadata and optional content reference. Supports extensions for archive files, NTFS streams, PE binaries, PDF documents, and raster images.</skos:definition>
        <skos:prefLabel xml:lang="en">File Object</skos:prefLabel>
    </owl:Class>
    


