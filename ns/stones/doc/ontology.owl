        <skos:definition>Represents a geographic location. May be as specific as a latitude/longitude coordinate or as broad as a continent. At least one of region, country, or latitude/longitude must be provided.</skos:definition>
        <skos:prefLabel xml:lang="en">Location</skos:prefLabel>
    </owl:Class>
    


