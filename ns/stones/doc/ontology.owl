        <rdfs:subClassOf rdf:resource="https://cyberterrain.org/ns/stones#StixDomainObject"/>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>A grouped set of adversarial behaviours and resources with common properties, believed to be orchestrated by a single organisation. Often represents a named APT group.</skos:definition>
        <skos:prefLabel xml:lang="en">Intrusion Set</skos:prefLabel>
    </owl:Class>
    


    <!-- https://cyberterrain.org/ns/stones#KillChainPhase -->


    <owl:Class rdf:about="https://cyberterrain.org/ns/stones#KillChainPhase">
        <rdfs:subClassOf rdf:resource="https://cyberterrain.org/ns/stones#StixSubType"/>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Represents a phase within a named kill chain framework, such as the MITRE ATT&amp;CK or Lockheed Martin Cyber Kill Chain, used to categorise the stage of an attack.</skos:definition>
        <skos:prefLabel xml:lang="en">Kill Chain Phase</skos:prefLabel>
    </owl:Class>
    


    <!-- https://cyberterrain.org/ns/stones#LanguageContentObject -->


    <owl:Class rdf:about="https://cyberterrain.org/ns/stones#LanguageContentObject">
