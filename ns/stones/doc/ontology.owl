    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#nameEnc -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#nameEnc">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#FileObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: name_enc)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
