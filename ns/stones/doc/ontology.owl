    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#isActive">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#NetworkTrafficObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>(STIX: is_active)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>True if this network traffic flow was still active when it was observed.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#isBlocking -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#isBlocking">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>(STIX: socket-ext.is_blocking)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>True if this socket is in blocking mode.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#isDisabled -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#isDisabled">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#UserAccountObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>(STIX: is_disabled)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>True if this account is currently disabled.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#isFamily -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#isFamily">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Malware"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>(STIX: is_family)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>True if this represents a malware family; false for a specific instance or sample.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#isHidden -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#isHidden">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#ProcessObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>(STIX: is_hidden)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>If true, this process is hidden from normal process enumeration.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#isListening -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#isListening">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>(STIX: socket-ext.is_listening)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>True if this socket is in a listening state.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#isMultipart -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#isMultipart">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#EmailMessageObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>(STIX: is_multipart)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>True if this email uses multipart MIME (bodyMultipart is populated); false if body contains the single plain-text body.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#isOptimized -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#isOptimized">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>(STIX: pdf-ext.is_optimized)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>True if the PDF is linearized (optimised for fast web viewing).</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#isPrivileged -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#isPrivileged">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#UserAccountObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>(STIX: is_privileged)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>True if this account has elevated privileges.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#isSelfSigned -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#isSelfSigned">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509CertificateObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>(STIX: is_self_signed)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>True if this certificate is self-signed.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#isServiceAccount -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#isServiceAccount">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#UserAccountObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>(STIX: is_service_account)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>True if this is a service or system account rather than a user account.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#issuer -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#issuer">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509CertificateObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: issuer)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Distinguished Name of the certificate issuer.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#issuerAlternativeName -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#issuerAlternativeName">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509V3Extensions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: x509-v3-extensions-type.issuer_alternative_name)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>X.509 v3 issuer alternative name extension.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#key -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#key">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#WindowsRegistryKeyObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: key)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Full Windows Registry key path, e.g. &apos;HKEY_LOCAL_MACHINE\Software\...&apos;.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#keyUsage -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#keyUsage">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509V3Extensions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: x509-v3-extensions-type.key_usage)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>X.509 v3 key usage extension value.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#killChainName -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#killChainName">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#KillChainPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: kill_chain_name)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Name of the kill chain framework, e.g. &apos;mitre-attack&apos;, &apos;lockheed-martin-cyber-kill-chain&apos;.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#labels -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#labels">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#StixObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: labels)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Free-form string terms applying to this object. Multiple labels are expressed as multiple triples.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#lang -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#lang">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: lang)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>BCP 47 language tag for the human-readable content of this object, e.g. &apos;en&apos;, &apos;fr&apos;. Also used in GranularMarking.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#languages -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#languages">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#SoftwareObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: languages)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>BCP 47 language tags for languages supported by this software. Multiple values as multiple triples.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#lastObserved -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#lastObserved">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#ObservedData"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: last_observed)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Latest timestamp at which this observation occurred. MUST be &gt;= firstObserved.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#lastSeen -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#lastSeen">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: last_seen)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Timestamp when this object was last observed or seen. MUST be &gt;= firstSeen.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#latitude -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#latitude">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>(STIX: latitude)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Latitude in decimal degrees, range -90 to 90. Required when longitude is present.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#longitude -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#longitude">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>(STIX: longitude)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Longitude in decimal degrees, range -180 to 180. Required when latitude is present.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#machineHex -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#machineHex">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment>(STIX: machine_hex)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Machine type from the COFF header as a hex value.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#magicNumberHex -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#magicNumberHex">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#FileObject"/>
