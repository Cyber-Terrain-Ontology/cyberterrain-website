    <!-- https://cyberterrain.org/ns/stones#Vulnerability -->


    <owl:Class rdf:about="https://cyberterrain.org/ns/stones#Vulnerability">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://cyberterrain.org/ns/stones#StixObject"/>
