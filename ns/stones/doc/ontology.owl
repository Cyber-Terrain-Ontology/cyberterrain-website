        <skos:prefLabel xml:lang="en">Language Content Object</skos:prefLabel>
    </owl:Class>
    


    <!-- https://cyberterrain.org/ns/stones#Location -->


    <owl:Class rdf:about="https://cyberterrain.org/ns/stones#Location">
        <owl:equivalentClass>
