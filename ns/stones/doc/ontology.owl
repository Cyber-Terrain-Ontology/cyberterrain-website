        <skos:definition>Represents a Windows Registry key with its full path, value entries, modification timestamp, and creator.</skos:definition>
        <skos:prefLabel xml:lang="en">Windows Registry Key Object</skos:prefLabel>
    </owl:Class>
    


    <!-- https://cyberterrain.org/ns/stones#WindowsRegistryValue -->


