    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#numberOfSections -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#numberOfSections">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>(STIX: number_of_sections)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
