        <rdfs:subClassOf rdf:resource="https://cyberterrain.org/ns/stones#StixCyberobservableObject"/>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Represents a Uniform Resource Locator conforming to RFC 3986.</skos:definition>
        <skos:prefLabel xml:lang="en">URL Object</skos:prefLabel>
    </owl:Class>
    


    <!-- https://cyberterrain.org/ns/stones#UserAccountObject -->


    <owl:Class rdf:about="https://cyberterrain.org/ns/stones#UserAccountObject">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://cyberterrain.org/ns/stones#StixObject"/>
