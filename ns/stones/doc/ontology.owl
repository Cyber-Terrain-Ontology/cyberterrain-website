        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>A single value entry within a Windows Registry key, comprising a name, a data string, and a registry data type.</skos:definition>
        <skos:prefLabel xml:lang="en">Windows Registry Value</skos:prefLabel>
    </owl:Class>
    


