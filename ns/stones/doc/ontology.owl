        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>(STIX: number)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Autonomous System number (ASN).</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#numberObserved -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#numberObserved">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#ObservedData"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>(STIX: number_observed)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
