        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>An NTFS Alternate Data Stream (ADS) attached to a file, identified by name with optional hashes and size.</skos:definition>
        <skos:prefLabel xml:lang="en">Alternate Data Stream</skos:prefLabel>
    </owl:Class>
    


    <!-- https://cyberterrain.org/ns/stones#ArtifactObject -->


    <owl:Class rdf:about="https://cyberterrain.org/ns/stones#ArtifactObject">
