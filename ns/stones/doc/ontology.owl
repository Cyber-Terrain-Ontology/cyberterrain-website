        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Represents a sequence of bytes, such as the content of a file, a raw stream of network traffic, or a data blob captured from memory. The content may be embedded directly via payload_bin or referenced via url.</skos:definition>
        <skos:prefLabel xml:lang="en">Artifact Object</skos:prefLabel>
    </owl:Class>
    


