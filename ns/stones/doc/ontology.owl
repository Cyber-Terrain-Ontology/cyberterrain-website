    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#mtime -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#mtime">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: mtime)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Last-modified timestamp of a file system object.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#name -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#name">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: name)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Human-readable name. Used across SDOs, SCOs, and sub-objects.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#nameConstraints -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#nameConstraints">
