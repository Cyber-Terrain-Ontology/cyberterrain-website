        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: objective)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Primary goal or objective of the campaign.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#path -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#path">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: path)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Absolute file system path (directory, file).</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#pathEnc -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#pathEnc">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: path_enc)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Character encoding used for the path property when the path contains non-ASCII characters.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#pattern -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#pattern">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: pattern)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Detection pattern expression, e.g. a STIX patterning language expression.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#patternVersion -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#patternVersion">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: pattern_version)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Version of the pattern language, e.g. the STIX patterning language version.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#payloadBin -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#payloadBin">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#ArtifactObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#base64Binary"/>
        <rdfs:comment>(STIX: payload_bin)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Artifact byte content encoded as base64. Mutually exclusive with url.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#pdfid0 -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#pdfid0">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: pdf-ext.pdfid0)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>First PDF file identifier string from the PDF trailer.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#pdfid1 -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#pdfid1">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: pdf-ext.pdfid1)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Second PDF file identifier string from the PDF trailer.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#phaseName -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#phaseName">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#KillChainPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: phase_name)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Phase within the kill chain, e.g. &apos;execution&apos;, &apos;persistence&apos;, &apos;lateral-movement&apos;.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#pid -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#pid">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#ProcessObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>(STIX: pid)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Process ID (PID).</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#pointerToSymbolTableHex -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#pointerToSymbolTableHex">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment>(STIX: pointer_to_symbol_table_hex)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>File offset of the COFF symbol table as hex.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#policyConstraints -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#policyConstraints">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509V3Extensions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: x509-v3-extensions-type.policy_constraints)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>X.509 v3 policy constraints extension value.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#policyMappings -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#policyMappings">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509V3Extensions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: x509-v3-extensions-type.policy_mappings)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>X.509 v3 policy mappings extension.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#postalCode -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#postalCode">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: postal_code)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Postal or ZIP code.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#precision -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#precision">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>(STIX: precision)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Radius of accuracy in metres around the latitude/longitude point.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#priority -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#priority">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: windows-process-ext.priority)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Scheduling priority string for this Windows process, e.g. &apos;HIGH_PRIORITY_CLASS&apos;.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#privateKeyUsagePeriodNotAfter -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#privateKeyUsagePeriodNotAfter">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509V3Extensions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: x509-v3-extensions-type.private_key_usage_period_not_after)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>End of the private key usage period.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#privateKeyUsagePeriodNotBefore -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#privateKeyUsagePeriodNotBefore">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509V3Extensions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: x509-v3-extensions-type.private_key_usage_period_not_before)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Start of the private key usage period.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#product -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#product">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#MalwareAnalysis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: product)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Name of the analysis tool used, e.g. &apos;Cuckoo&apos;, &apos;VirusTotal&apos;.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#protocols -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#protocols">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#NetworkTrafficObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: protocols)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Ordered list of protocols from lowest to highest layer, e.g. &apos;ipv4&apos;, &apos;tcp&apos;, &apos;http&apos;. Multiple values as multiple triples.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#published -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#published">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Report"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: published)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Date and time this report was published.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#receivedLines -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#receivedLines">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#EmailMessageObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: received_lines)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Received: header values in the order received. Multiple values as multiple triples.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#relationshipType -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#relationshipType">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Relationship"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: relationship_type)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Semantic type of this relationship, e.g. &apos;uses&apos;, &apos;targets&apos;, &apos;indicates&apos;.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#requestMethod -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#requestMethod">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: http-request-ext.request_method)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>HTTP method, e.g. &apos;GET&apos;, &apos;POST&apos;.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#requestValue -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#requestValue">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: http-request-ext.request_value)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>HTTP request URI path, e.g. &apos;/index.html?q=1&apos;.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#requestVersion -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#requestVersion">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: http-request-ext.request_version)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>HTTP version string, e.g. &apos;HTTP/1.1&apos;.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#resultName -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#resultName">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#MalwareAnalysis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: result_name)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Classification name from the analysis product.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#revoked -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#revoked">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#StixObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>(STIX: revoked)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>If true, this object has been revoked and should no longer be considered accurate.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#rir -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#rir">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#AutonomousSystemObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: rir)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Regional Internet Registry that assigned this ASN, e.g. &apos;ARIN&apos;, &apos;RIPE&apos;.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#roles -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#roles">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Identity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: roles)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Free-form roles this identity plays, e.g. &apos;analyst&apos;. For threat-actor roles see the object property stones:threatActorRoles.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#schema -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#schema">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#ExtensionDefinitionObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: schema)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>URL pointing to, or the raw content of, the JSON Schema defining this extension.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#selectors -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#selectors">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#GranularMarking"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: selectors)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>JSON property path selectors identifying the properties this marking applies to, e.g. &apos;name&apos;, &apos;description&apos;. Multiple values as multiple triples.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#serialNumber -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#serialNumber">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509CertificateObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: serial_number)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Serial number assigned to this certificate by the issuer.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#serviceName -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#serviceName">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: windows-service-ext.service_name)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Windows service name as used in the Service Control Manager.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#shell -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#shell">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#UserAccountObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: unix-account-ext.shell)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Login shell path for this UNIX account, e.g. &apos;/bin/bash&apos;.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#sid -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#sid">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: sid / owner_sid)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Windows Security Identifier (SID) of the file owner (ntfs-ext) or process owner (windows-process-ext).</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#signatureAlgorithm -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#signatureAlgorithm">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509CertificateObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: signature_algorithm)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Algorithm used to sign this certificate, e.g. &apos;sha256WithRSAEncryption&apos;.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#size -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#size">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>(STIX: size)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Size in bytes (file, windows-pe-section, alternate-data-stream).</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#sizeOfOptionalHeader -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#sizeOfOptionalHeader">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>(STIX: size_of_optional_header)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Size of the optional PE header in bytes.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#socketDescriptor -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#socketDescriptor">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>(STIX: socket-ext.socket_descriptor)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Platform-specific socket file descriptor number.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#socketHandle -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#socketHandle">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>(STIX: socket-ext.socket_handle)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Windows handle value for this socket.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#sourceName -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#sourceName">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#ExternalReference"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: source_name)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Name of the information source, e.g. &apos;mitre-attack&apos;, &apos;cve&apos;, &apos;capec&apos;.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#specVersion -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#specVersion">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#StixObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: spec_version)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>STIX specification version. MUST be &apos;2.1&apos;.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#srcByteCount -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#srcByteCount">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#NetworkTrafficObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>(STIX: src_byte_count)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Total bytes sent from source to destination.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#srcFlagsHex -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#srcFlagsHex">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment>(STIX: tcp-ext.src_flags_hex)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>TCP flags set on packets from the source endpoint as hex, e.g. &apos;0x02&apos; for SYN.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#srcPackets -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#srcPackets">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#NetworkTrafficObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>(STIX: src_packets)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Number of packets sent from source to destination.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#srcPort -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#srcPort">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#NetworkTrafficObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>(STIX: src_port)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Source port number (0–65535).</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#start -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#start">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#NetworkTrafficObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: start)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Timestamp when this network traffic flow started.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#startTime -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#startTime">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Relationship"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: start_time)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Timestamp when this relationship began.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#statement -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#statement">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: definition.statement)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Human-readable statement for a statement marking definition, e.g. a copyright notice.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#stixId -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#stixId">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#StixObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: id)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>The STIX identifier string in the format &lt;type&gt;--&lt;UUIDv4&gt;. The IRI of the individual is the canonical identity; this property retains the string for JSON round-tripping and SPARQL querying.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#stixType -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#stixType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#StixObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: type)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>The STIX object type string, e.g. &apos;attack-pattern&apos;. Semantically redundant with rdf:type but preserved for JSON round-tripping.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#stopTime -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#stopTime">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Relationship"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: stop_time)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Timestamp when this relationship ended. MUST be &gt;= startTime.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#streetAddress -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#streetAddress">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: street_address)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Street address.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#subject -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#subject">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: subject)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Subject line of an email message, or Distinguished Name of the certificate subject.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#subjectAlternativeName -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#subjectAlternativeName">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509V3Extensions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: x509-v3-extensions-type.subject_alternative_name)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>X.509 v3 subject alternative name extension.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#subjectDirectoryAttributes -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#subjectDirectoryAttributes">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509V3Extensions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: x509-v3-extensions-type.subject_directory_attributes)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>X.509 v3 subject directory attributes extension.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#subjectKeyIdentifier -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#subjectKeyIdentifier">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509V3Extensions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: x509-v3-extensions-type.subject_key_identifier)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>X.509 v3 subject key identifier.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#subjectPublicKeyAlgorithm -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#subjectPublicKeyAlgorithm">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509CertificateObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: subject_public_key_algorithm)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Algorithm of the subject&apos;s public key, e.g. &apos;rsaEncryption&apos;.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#subjectPublicKeyExponent -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#subjectPublicKeyExponent">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509CertificateObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>(STIX: subject_public_key_exponent)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>RSA public exponent of the subject&apos;s public key.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#subjectPublicKeyModulus -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#subjectPublicKeyModulus">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509CertificateObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: subject_public_key_modulus)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>RSA modulus of the subject&apos;s public key as a hex string.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#submitted -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#submitted">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#MalwareAnalysis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: submitted)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Timestamp when the sample was submitted for analysis.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#summary -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#summary">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Sighting"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>(STIX: summary)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>If true, this sighting aggregates multiple observations rather than recording a single specific event.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#swid -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#swid">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#SoftwareObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: swid)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>ISO/IEC 19770-2 SWID tag identifier.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#timeDateStamp -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#timeDateStamp">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: time_date_stamp)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Timestamp recorded in the PE header.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#tlp -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#tlp">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: definition.tlp)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>TLP level for a TLP marking definition: &apos;white&apos;, &apos;green&apos;, &apos;amber&apos;, or &apos;red&apos;.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#toolVersion -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#toolVersion">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Tool"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: tool_version)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Version string of the tool.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#uid -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#uid">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#UserAccountObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>(STIX: unix-account-ext.uid)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Numeric UNIX user ID (UID).</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#url -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#url">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment>(STIX: url)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>URL to a referenced resource (external-reference) or the location of artifact content.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#userId -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#userId">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#UserAccountObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: user_id)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Identifier of the user account, such as a login name or UID.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#validFrom -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#validFrom">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: valid_from)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Timestamp from which this indicator is considered valid.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#validUntil -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#validUntil">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: valid_until)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Timestamp after which this indicator is no longer valid.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#validityNotAfter -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#validityNotAfter">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509CertificateObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: validity_not_after)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>End of the certificate validity period.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#validityNotBefore -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#validityNotBefore">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#X509CertificateObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: validity_not_before)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Start of the certificate validity period.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#value -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#value">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: value)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Primary string value of an observable: the domain name, email address, IP address, MAC address, or URL.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#vendor -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#vendor">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#SoftwareObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: vendor)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Name of the software vendor.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#version -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#version">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: version)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Version string. Used for analysis tool version (malware-analysis), schema version (extension-definition), software version, X.509 version, and PDF format version.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#windowTitle -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#windowTitle">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: windows-process-ext.window_title)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Title text of the main window of this Windows process.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2004/02/skos/core#Collection -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Collection">
        <owl:disjointWith rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <owl:disjointWith rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="en">Collection</rdfs:label>
        <skos:definition xml:lang="en">A meaningful collection of concepts.</skos:definition>
        <skos:scopeNote xml:lang="en">Labelled collections can be used where you would like a set of concepts to be displayed under a &apos;node label&apos; in the hierarchy.</skos:scopeNote>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept">
        <owl:disjointWith rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="en">Concept</rdfs:label>
        <skos:definition xml:lang="en">An idea or notion; a unit of thought.</skos:definition>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#ConceptScheme -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="en">Concept Scheme</rdfs:label>
        <skos:definition xml:lang="en">A set of concepts, optionally including statements about semantic relationships between those concepts.</skos:definition>
        <skos:example xml:lang="en">Thesauri, classification schemes, subject heading lists, taxonomies, &apos;folksonomies&apos;, and other types of controlled vocabulary are all examples of concept schemes. Concept schemes are also embedded in glossaries and terminologies.</skos:example>
        <skos:scopeNote xml:lang="en">A concept scheme may be defined to include concepts from different sources.</skos:scopeNote>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#OrderedCollection -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#OrderedCollection">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Collection"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="en">Ordered Collection</rdfs:label>
        <skos:definition xml:lang="en">An ordered collection of concepts, where both the grouping and the ordering are meaningful.</skos:definition>
        <skos:scopeNote xml:lang="en">Ordered collections can be used where you would like a set of concepts to be displayed in a specific order, and optionally under a &apos;node label&apos;.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://cyberterrain.org/ns/stones#AccountTypeVocabulary -->


