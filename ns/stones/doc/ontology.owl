                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://cyberterrain.org/ns/stones#StixObject"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://cyberterrain.org/ns/stones#stixType"/>
                        <owl:hasValue>infrastructure</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://cyberterrain.org/ns/stones#StixDomainObject"/>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Represents systems, software services, or any group of resources used to conduct cyber operations. Infrastructure is used by threat actors and intrusion sets both offensively and defensively.</skos:definition>
        <skos:prefLabel xml:lang="en">Infrastructure</skos:prefLabel>
    </owl:Class>
    


    <!-- https://cyberterrain.org/ns/stones#InfrastuctureTypeVocabulary -->


    <owl:Class rdf:about="https://cyberterrain.org/ns/stones#InfrastuctureTypeVocabulary">
        <rdfs:subClassOf rdf:resource="https://cyberterrain.org/ns/stones#OpenVocabulary"/>
    </owl:Class>
    


    <!-- https://cyberterrain.org/ns/stones#IntrusionSet -->


    <owl:Class rdf:about="https://cyberterrain.org/ns/stones#IntrusionSet">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://cyberterrain.org/ns/stones#StixObject"/>
                    <owl:Restriction>
