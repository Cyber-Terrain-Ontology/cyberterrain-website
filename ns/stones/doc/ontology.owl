    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#numberOfSubkeys -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#numberOfSubkeys">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#WindowsRegistryKeyObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>(STIX: number_of_subkeys)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Number of subkeys under this registry key.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#numberOfSymbols -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#numberOfSymbols">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>(STIX: number_of_symbols)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Number of entries in the COFF symbol table.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#objectModified -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#objectModified">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#LanguageContentObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: object_modified)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
