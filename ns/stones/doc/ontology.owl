        <skos:definition>Represents a user account on a system or service, including local OS accounts, cloud accounts, and social media accounts. Supports a unix-account extension for POSIX attributes.</skos:definition>
        <skos:prefLabel xml:lang="en">User Account Object</skos:prefLabel>
    </owl:Class>
    


