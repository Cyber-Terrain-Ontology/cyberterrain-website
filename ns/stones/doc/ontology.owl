    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#messageBodyLength -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#messageBodyLength">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>(STIX: http-request-ext.message_body_length)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Length of the HTTP message body in bytes.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#messageId -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#messageId">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#EmailMessageObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: message_id)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Value of the Message-ID header.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#mimeType -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#mimeType">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: mime_type)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>IANA MIME type of the content (artifact, file).</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#modified -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#modified">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: modified)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Timestamp when this object was last modified. MUST be &gt;= created.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#modifiedTime -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#modifiedTime">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#WindowsRegistryKeyObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>(STIX: modified_time)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
        <skos:definition>Last modification timestamp of this registry key.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cyberterrain.org/ns/stones#modules -->


    <owl:DatatypeProperty rdf:about="https://cyberterrain.org/ns/stones#modules">
        <rdfs:domain rdf:resource="https://cyberterrain.org/ns/stones#MalwareAnalysis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>(STIX: modules)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://cyberterrain.org/ns/stones#"/>
