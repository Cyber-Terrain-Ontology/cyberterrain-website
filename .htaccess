
# Ontology namespace: content negotiation for /ns/* (must run before WordPress)
# Uses 303 redirects to avoid mod_dir/mod_rewrite ordering issues.
# Pattern [^/.] matches bare names only (e.g. "stones"), not "stones.ttl" or "stones/doc/..."
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# RDF/semantic web clients: 303 redirect to Turtle
RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/x-turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml [OR]
RewriteCond %{HTTP_ACCEPT} application/owl\+xml
RewriteRule ^ns/([^/.]+)/?$ /ns/$1.ttl [R=303,L]

# Browsers: 303 redirect to HTML
RewriteRule ^ns/([^/.]+)/?$ /ns/$1.html [R=303,L]
</IfModule>

# BEGIN WordPress
# The directives (lines) between "BEGIN WordPress" and "END WordPress" are
# dynamically generated, and should only be modified via WordPress filters.
# Any changes to the directives between these markers will be overwritten.
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteBase /
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>

# END WordPress